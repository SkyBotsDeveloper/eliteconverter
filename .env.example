APP_ENV=development
APP_BASE_URL=http://127.0.0.1:8787
API_BASE_URL=http://127.0.0.1:8787/api/v1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

API_KEY_HASH_SECRET=replace-with-a-long-random-secret
CLIENT_WEBHOOK_SIGNING_SECRET=replace-with-a-long-random-secret

ENABLED_PROVIDERS=mock
PROVIDER_PRIORITY=mock

GENERIC_PROVIDER_BASE_URL=
GENERIC_PROVIDER_API_KEY=
GENERIC_PROVIDER_AUTH_HEADER=Authorization
GENERIC_PROVIDER_AUTH_SCHEME=Bearer
GENERIC_PROVIDER_CREATE_PATH=/jobs
GENERIC_PROVIDER_STATUS_PATH=/jobs/{id}
GENERIC_PROVIDER_CANCEL_PATH=/jobs/{id}/cancel
GENERIC_PROVIDER_REFRESH_PATH=/jobs/{id}/download
GENERIC_PROVIDER_WEBHOOK_SECRET=
GENERIC_PROVIDER_TIMEOUT_MS=10000

MAX_PROVIDER_ATTEMPTS=3
MAX_RETRY_ATTEMPTS=3
INITIAL_RETRY_DELAY_MS=1000
MAX_RETRY_DELAY_MS=60000
JOB_EXPIRATION_HOURS=24
STUCK_JOB_THRESHOLD_MINUTES=15
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
MAX_CONCURRENT_JOBS_PER_USER=5
MAX_ANONYMOUS_JOBS_PER_DAY=20
